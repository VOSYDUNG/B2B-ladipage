# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Client Configuration for Frontend Integration
VITE_FIREBASE_API_KEY="your_api_key"
VITE_FIREBASE_AUTH_DOMAIN="nnccampaignplatformproduction.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="nnccampaignplatformproduction"
VITE_FIREBASE_STORAGE_BUCKET="nnccampaignplatformproduction.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="659401525984"
VITE_FIREBASE_APP_ID="1:659401525984:web:87d54441766c4a051cde85"
VITE_FIREBASE_MEASUREMENT_ID="G-KKFLNDWVP4"
# Preferred for new App Check integrations.
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY="your_recaptcha_enterprise_site_key"
# Legacy fallback only when Enterprise is not available.
VITE_RECAPTCHA_V3_SITE_KEY="your_recaptcha_v3_site_key"
# Keep false for the direct Firestore Lead architecture.
VITE_USE_CLOUD_FUNCTIONS="false"
