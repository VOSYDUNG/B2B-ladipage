{
  "name": "nnc-campaign-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "npm run test:campaign && npm run test:security",
    "test:campaign": "tsx --test src/config/white-lotus-*.test.ts src/config/nnc-*.test.ts src/components/nnc-b2b-rewards/*.test.ts src/lib/landing-service.test.ts src/lib/lead-export.test.ts",
    "test:promotion": "npm run test:campaign",
    "test:security": "node --test tests/firestore-boundary.test.cjs",
    "test:rules:integration": "firebase emulators:exec --only firestore \"node --test tests/nnc-firestore-rules.integration.test.mjs\""
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.15",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tabs": "^1.1.16",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "playwright": "^1.61.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.80.0",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
